# Copy to .env and adjust as needed: cp .env.example .env

# WebUI public port
PORT=6789

# Ollama address (inside the container, reach the host via host.docker.internal;
# do NOT use localhost here)
OLLAMA_URL=http://host.docker.internal:11434

# ===== Claude engine (optional; alternative to Ollama) =====
# Mount your already-logged-in Claude credentials directory into the container
# to enable the Claude engine. Must be an absolute path, usually your ~/.claude:
#   CLAUDE_CREDS_DIR=/home/your-name/.claude
# Leave empty to keep the Claude engine unavailable (Ollama still works).
CLAUDE_CREDS_DIR=

# Claude model aliases (comma-separated; `claude --model` accepts aliases)
CLAUDE_MODELS=sonnet,opus,haiku

# claude executable inside the container (defaults to the version installed in the image)
CLAUDE_BIN=claude

# ===== OpenAI Codex engine (optional; alternative to Ollama) =====
# Mount your already-logged-in Codex credentials directory into the container
# to enable the Codex engine. Must be an absolute path, usually your ~/.codex:
#   CODEX_CREDS_DIR=/home/your-name/.codex
# Leave empty to keep the Codex engine unavailable (Ollama still works).
CODEX_CREDS_DIR=

# Codex models (comma-separated; passed to `codex exec -m`).
# ChatGPT-account logins only support gpt-5.5; models like gpt-5 / gpt-5.1 /
# gpt-5-codex require an API-key account — add them here if that's your setup.
CODEX_MODELS=gpt-5.5

# codex executable inside the container (defaults to the version installed in the image)
CODEX_BIN=codex
