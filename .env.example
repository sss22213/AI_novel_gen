# Copy to .env and adjust as needed: cp .env.example .env

# WebUI public port
PORT=6789

# Ollama address (inside the container, reach the host via host.docker.internal;
# do NOT use localhost here)
OLLAMA_URL=http://host.docker.internal:11434

# ===== Claude engine (optional; alternative to Ollama) =====
# Mount your already-logged-in Claude credentials directory into the container
# to enable the Claude engine. Must be an absolute path, usually your ~/.claude:
#   CLAUDE_CREDS_DIR=/home/your-name/.claude
# Leave empty to keep the Claude engine unavailable (Ollama still works).
CLAUDE_CREDS_DIR=

# Claude model aliases (comma-separated; `claude --model` accepts aliases)
CLAUDE_MODELS=sonnet,opus,haiku

# claude executable inside the container (defaults to the version installed in the image)
CLAUDE_BIN=claude
